@model WebApplicationDevFinalProject.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header text-white ct-header">
                <h3 class="mb-0">@Model.Title</h3>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Genre</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Genre)</dd>

                    <dt class="col-sm-3 text-muted">Release Year</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.ReleaseYear)</dd>

                    <dt class="col-sm-3 text-muted">Rating</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-warning text-dark fs-6">@Html.DisplayFor(model => model.Rating) / 10</span>
                    </dd>

                    <dt class="col-sm-3 text-muted">Description</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>
                </dl>
            </div>
            <div class="card-footer bg-light">
                <a asp-action="Genre" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>