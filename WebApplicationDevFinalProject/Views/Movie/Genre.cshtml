@model IEnumerable<WebApplicationDevFinalProject.Models.Movie>

@{
    ViewData["Title"] = "Browse by Genre";
    var genres = new[] { "Action", "Adventure", "Animation", "Comedy", "Crime", "Drama", "Fantasy", "Horror", "Romance", "Sci-Fi", "Thriller" };
    var currentGenre = Context.Request.Query["genreStr"].ToString();
}

<div class="text-white py-4 px-4 mb-4 rounded d-flex justify-content-between align-items-center ct-header">
    <div>
        <h1 class="display-5 fw-bold mb-0">Browse by Genre</h1>
        <p class="mb-0 text-white-50">Filter movies by genre or view the full collection.</p>
    </div>
    <a asp-action="AddMovie" class="btn btn-light fw-semibold">+ Add a Movie</a>
</div>

<form asp-controller="Movie" asp-action="Genre" method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label fw-semibold">Genre</label>
            <select name="genreStr" class="form-select">
                <option value="">All Genres</option>
                @foreach (var g in genres)
                {
                    <option value="@g" selected="@(currentGenre == g ? "selected" : null)">@g</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-dark">Filter</button>
            @if (!string.IsNullOrEmpty(currentGenre))
            {
                <a asp-action="Genre" class="btn btn-outline-secondary ms-1">Clear</a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No movies found for this genre. Try a different filter or <a asp-action="AddMovie">add a movie</a>.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="ct-header text-white">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Title)</th>
                    <th>@Html.DisplayNameFor(model => model.Genre)</th>
                    <th>@Html.DisplayNameFor(model => model.ReleaseYear)</th>
                    <th>@Html.DisplayNameFor(model => model.Rating)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>@Html.DisplayFor(modelItem => item.Genre)</td>
                        <td>@Html.DisplayFor(modelItem => item.ReleaseYear)</td>
                        <td>@Html.DisplayFor(modelItem => item.Rating)</td>
                        <td>
                            <a asp-action="MovieDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark me-1">Details</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this movie?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}