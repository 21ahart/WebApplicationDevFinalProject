@{
    ViewData["Title"] = "Top 100";
}

<div class="text-white py-5" style="background: linear-gradient(90deg, #111827, #1f2937);">
    <div class="container">
        <h1 class="display-3 fw-bold" style="letter-spacing: 2px;">TOP 100</h1>        
        <p class="lead">Curated films. Ranked favorites. The final cut.</p>
    </div>
</div>

<div class="container mt-5">
    <h2 class="mb-4">Top 10 Highlights</h2>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h3>#1 The Shawshank Redemption</h3>
                    <p class="text-muted">Drama • 1994</p>
                    <span class="badge bg-warning text-dark">9.3</span>
                    <p class="mt-3">A powerful story of hope, resilience, and redemption.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h3>#2 The Godfather</h3>
                    <p class="text-muted">Crime • 1972</p>
                    <span class="badge bg-warning text-dark">9.2</span>
                    <p class="mt-3">An iconic crime film with unforgettable performances.</p>
                </div>
            </div>
        </div>
    </div>

