@model IEnumerable<WebApplicationDevFinalProject.Models.Movie>

@{
    ViewData["Title"] = "Top 100";
}

<div class="text-white py-5 ct-header">
    <div class="container">
        <h1 class="display-3 fw-bold" style="letter-spacing: 2px;">TOP 100</h1>
        <p class="lead">Pulled from your movie database.</p>
    </div>
</div>

<div class="container mt-5">
    @if (!Model.Any())
    {
        <div class="alert alert-info">No movies found. Add movies first to populate this page.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                    <thead class="ct-header text-white">
                    <tr>
                        <th>Rank</th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Year</th>
                        <th>Rating</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var rank = 1;
                    }
                    @foreach (var movie in Model)
                    {
                        <tr>
                            <td>@rank</td>
                            <td>@movie.Title</td>
                            <td>@movie.Genre</td>
                            <td>@movie.ReleaseYear</td>
                            <td>@movie.Rating</td>
                            <td>
                                <a asp-controller="Movie" asp-action="MovieDetails" asp-route-id="@movie.Id">Details</a>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>